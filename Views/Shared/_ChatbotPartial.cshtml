<div class="chat-panel modal-chat" id="chatPanel" aria-hidden="true">
    <!-- Header -->
    <div class="chat-header">
        <div class="chat-avatar">DA</div>
        <div class="chat-title">
            <h4>Doctor Asklepios.ai</h4>
            <span class="chat-subtitle">GPT-6 • 218 LLMs • 118 left this month</span>
        </div>
        <button class="close-chat-btn" id="closeChat" aria-label="Close chat">×</button>
    </div>

    <!-- Body -->
    <div class="chat-body" id="chatBody">
        <div class="bubble bot">
            <strong>Hi! I'm Doctor Asklepios 👋</strong><br />
            Upload your image and click <strong>Suggestion</strong> to get AI-powered insights.
        </div>
    </div>

    <!-- Footer -->
    <div class="chat-footer">
        <input type="text" id="chatInput" placeholder="Send your message to Doctor Asklepios..." />
        <button id="sendChat">Send</button>
    </div>
</div>