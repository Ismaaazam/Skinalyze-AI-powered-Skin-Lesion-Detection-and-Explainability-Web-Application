@model Skinalyze.ViewModels.PredictionResultViewModel

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">

        @foreach (var error in ViewData.ModelState.Values
       .SelectMany(v => v.Errors))
        {
            <p>@error.ErrorMessage</p>
        }

    </div>
}

@section Styles {
    <link rel="stylesheet" href="~/css/Upload.css" />
}

<div class="app-wrapper" id="appWrapper">
    <div class="page">

        <div class="page-header mb-4">
            <div>
                <h1 class="fw-bold">Upload Lesion Image</h1>
                <p class="text-muted mb-0">
                    Upload a clear lesion image for analysis.
                </p>
            </div>
        </div>

        <div class="single-column-content">

            <form asp-action="Upload"
                  method="post"
                  enctype="multipart/form-data">

                <!-- Upload Card -->
                <div class="card sk-card mb-4">

                    <div class="upload-section">

                        <div class="uploader">

                            <div class="icon">🖼️</div>

                            <p class="fw-semibold mt-2">
                                Click to Upload Image
                            </p>

                            <small class="text-muted">
                                .jpg, .png • Max 10MB
                            </small>

                            <input asp-for="ImageFile"
                                   id="fileInput"
                                   type="file"
                                   class="form-control mt-3" />

                        </div>

                        <div class="d-flex gap-2 mt-3">

                            <button type="submit"
                                    class="btn btn-success px-4">
                                Analyze Image
                            </button>

                        </div>

                    </div>

                </div>

            </form>

            <!-- Results Section -->
            <div id="resultSection" class="card sk-card mb-4">

                <h5 class="fw-bold mb-2">
                    Processed Results
                </h5>

                @if (Model.Prediction != null)
                {
                    <div class="mt-3">

                        <h5 class="fw-bold text-success">
                            Prediction: @Model.Prediction
                        </h5>

                        <p>
                            <strong>Confidence:</strong>
                            @Model.Confidence %
                        </p>

                        <p>
                            <strong>Severity:</strong>
                            @Model.Severity
                        </p>

                        <p>
                            <strong>Description:</strong>
                            @Model.Description
                        </p>

                        <p>
                            <strong>Recommendation:</strong>
                            @Model.Recommendation
                        </p>

                        <div class="row mt-3">

                            <div class="col-md-6 text-center">

                                <h6>Uploaded Image</h6>

                                <img src="@Model.UploadedImagePath"
                                     class="img-fluid border" style="max-height:300px;" />

                            </div>

                            <div class="col-md-6 text-center">

                                <h6>Grad-CAM Heatmap</h6>

                                <img src="data:image/png;base64,@Model.Heatmap"
                                     class="img-fluid border" style="max-height:300px;" />

                            </div>

                        </div>
                        <div class="mt-3">

                            <p class="mt-2">

                                <strong>Heatmap Interpretation:</strong>

                                <br />

                                @Model.HeatmapExplanation

                            </p>

                            <h6 class="fw-bold">
                                Heatmap Analysis
                            </h6>

                            <p>
                                <strong>Activation:</strong>
                                @Model.HighestActivation
                            </p>

                            <p>
                                <strong>Lesion Coverage:</strong>
                                @Model.CoveragePercent %
                            </p>

                            <p>
                                <strong>Active Zones:</strong>
                                @Model.ActiveZones
                            </p>

                        </div>

                    </div>
                }
                else
                {
                    <p class="text-muted">
                        Analysis results will appear here
                        after uploading image.
                    </p>
                }

            </div>

            @if (Model.Prediction != null)
            {
                <div class="mt-4 text-center">

                    <p class="fw-semibold">
                        Would you like to record these results in a report?
                    </p>

                    <a asp-action="ReportForm"
                       class="btn btn-success">

                        Generate Report

                    </a>

                </div>
            }

        </div>

    </div>

    @await Html.PartialAsync("_ChatbotPartial")

</div>

@section Scripts {
    <script src="~/js/Upload.js"></script>

    <script>

        window.addEventListener("load", function () {

            var hasResult =
                '@(Model.Prediction != null)' === 'True';

            if (hasResult) {

                var resultSection =
                    document.getElementById("resultSection");

                if (resultSection) {

                    resultSection.scrollIntoView({
                        behavior: "smooth"
                    });

                }

            }

        });

    </script>
}
