@model Skinalyze.ViewModels.PredictionResultViewModel

@if (!ViewData.ModelState.IsValid)
{
    foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
    {
        <div class="serverErrorMsg" data-message="@error.ErrorMessage" style="display:none;"></div>
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/Upload.css" />
}


@await Html.PartialAsync("_ChatbotPartial")

<div class="app-wrapper" id="appWrapper">
    <div class="page">

        <div class="page-header mb-4">
            <div>
                <h1 class="fw-bold">Upload Lesion Image</h1>
                <p class="text-muted mb-0">Upload a clear lesion image for analysis.</p>
            </div>
        </div>

        @await Html.PartialAsync("_UploadPolicy")

        <div class="single-column-content">

            <input type="hidden" id="hasResult" value="@(Model.Prediction != null)" />

            <form asp-action="Upload" method="post" enctype="multipart/form-data" id="uploadForm">

                <div class="upload-form-card">

                    <!-- Dropzone -->
                    <div class="uploader-inner" id="dropzone">

                        <div id="dropzoneContent">
                            <div class="upload-icon-wrap">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="3" width="18" height="18" rx="4" ry="4" />
                                    <circle cx="8.5" cy="8.5" r="1.5" />
                                    <polyline points="21 15 16 10 5 21" />
                                </svg>
                            </div>
                            <p class="upload-title">Click or Drag to Upload</p>
                            <p class="upload-sub">Accepts .jpg, .png &nbsp;·&nbsp; Max 10MB</p>
                            <label class="upload-browse-btn" for="fileInput">Browse File</label>
                        </div>

                        <!-- Preview (hidden until file selected) -->
                        <div id="previewState" style="display:none; width:100%; text-align:center;">
                            <img id="previewImg" src="" alt="Preview"
                                 style="max-height:200px; max-width:100%; border-radius:14px; object-fit:contain;" />
                        </div>

                        <input asp-for="ImageFile" id="fileInput" type="file"
                               accept="image/jpeg,image/png" style="display:none;" />
                    </div>

                    <!-- Validation message under dropzone -->
                    <p class="upload-field-error" id="fileError" style="display:none;">
                        ⚠ Please select an image before uploading.
                    </p>

                    <p class="upload-tip">Input clear picture, no filters, focus on lesion.</p>

                    <!-- Actions -->
                    <div class="upload-actions">
                        <button type="submit" class="btn-upload-pill" id="uploadBtn">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round" width="15" height="15">
                                <polyline points="16 16 12 12 8 16" />
                                <line x1="12" y1="12" x2="12" y2="21" />
                                <path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3" />
                            </svg>
                            Upload Image
                        </button>
                        <button type="button" id="clearBtn" class="btn-clear-pill">Clear</button>
                    </div>

                </div>

            </form>

            <!-- Results Section -->
            <div id="resultSection" class="card sk-card mb-4">

                <h5 class="fw-bold mb-2">Processed Results</h5>

                @if (Model.Prediction != null)
                {
                    <div class="mt-3">

                        <h5 class="fw-bold text-success">Prediction: @Model.Prediction</h5>

                        <p><strong>Confidence:</strong> @Model.Confidence %</p>
                        <p><strong>Severity:</strong> @Model.Severity</p>
                        <p><strong>Description:</strong> @Model.Description</p>
                        <p><strong>Recommendation:</strong> @Model.Recommendation</p>

                        <div class="row mt-3">
                            <div class="col-md-6 text-center">
                                <h6>Uploaded Image</h6>
                                <img src="@Model.UploadedImagePath"
                                     class="img-fluid border" style="max-height:300px;" />
                            </div>
                            <div class="col-md-6 text-center">
                                <h6>Grad-CAM Heatmap</h6>
                                <img src="data:image/png;base64,@Model.Heatmap"
                                     class="img-fluid border" style="max-height:300px;" />
                            </div>
                        </div>

                        <div class="mt-3">
                            <p class="mt-2">
                                <strong>Heatmap Interpretation:</strong><br />
                                @Model.HeatmapExplanation
                            </p>
                            <h6 class="fw-bold">Heatmap Analysis</h6>
                            <p><strong>Activation:</strong> @Model.HighestActivation</p>
                            <p><strong>Lesion Coverage:</strong> @Model.CoveragePercent %</p>
                            <p><strong>Active Zones:</strong> @Model.ActiveZones</p>
                        </div>

                    </div>
                }
                else
                {
                    <p class="text-muted">Analysis results will appear here after uploading image.</p>
                }

            </div>

            @if (Model.Prediction != null)
            {
                <div class="mt-4 text-center">
                    <p class="fw-semibold">Would you like to record these results in a report?</p>
                    <a asp-action="ReportForm" class="btn-report-pill">Generate Report</a>
                </div>
            }

        </div>

    </div>
</div>

 @section Scripts {
    <script src="~/js/Upload.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            initChatbot("overlay");

            //  Surface ModelState errors as toasts (server validation)
               // Change querySelectorAll from id to class
        document.querySelectorAll(".serverErrorMsg").forEach(function (el) {
            var msg = el.getAttribute("data-message");
            if (msg) showToast(msg, "error");
        });

            //  Surface TempData toast errors (confidence check, redirected errors)
                    @if (TempData["ToastError"] != null)
        {
                <text>
                    setTimeout(() => showToast("@TempData["ToastError"]", "error"), 100);
                </text>
        }

            @if (TempData["ToastSuccess"] != null)
            {
                <text>showToast("@TempData["ToastSuccess"]", "success");</text>
            }
        });
    </script>
}