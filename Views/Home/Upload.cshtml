@section Styles {
    <link rel="stylesheet" href="~/css/Upload.css" />
}
<div class="app-wrapper" id="appWrapper">
    <div class="page">

        <!-- Header -->
        <div class="page-header mb-4">
            <div>
                <h1 class="fw-bold">Upload Lesion Image</h1>
                <p class="text-muted mb-0">
                    Upload a clear lesion image for analysis. We'll process and provide a report.
                </p>
            </div>
        </div>

        <div class="single-column-content">

            <!-- 1. Upload -->
            <div class="card sk-card mb-4">
                <div class="upload-section">

                    <div class="uploader" id="dropzone">
                        <div class="icon">🖼️</div>
                        <p class="fw-semibold mt-2">Click or Drag to Upload</p>
                        <small class="text-muted">.jpg, .png • Max 10MB</small>

                        <div class="preview mt-3" id="uploadPreview" style="display:none;">
                            <img id="previewImg" />
                            <button id="removeImg" class="btn btn-sm btn-light mt-2">Remove</button>
                        </div>

                        <input id="fileInput" type="file" hidden />
                    </div>

                    <p class="text-muted mt-3 small">
                        Input clear picture, no filters, focus on lesion.
                    </p>

                    <div class="d-flex gap-2 mt-3">
                        <button id="uploadBtn" class="btn btn-success px-4">Upload Image</button>
                        <button id="clearBtn" class="btn btn-outline-secondary">Clear</button>
                    </div>

                </div>
            </div>

            <!-- 2. Policy -->
            <div class="card sk-card mb-4">
                <h5 class="fw-bold mb-3">Image Submission Guidelines</h5>
                <ul class="text-muted">
                    <li>Take a clear photo</li>
                    <li>Frame lesion clearly</li>
                    <li>Avoid blur or occlusion</li>
                    <li>Include scale reference if possible</li>
                </ul>

                <h6 class="fw-bold mt-4">Privacy</h6>
                <p class="text-muted small mb-0">
                    Images are securely processed and deleted after 30 days.
                </p>
            </div>

            <!-- 3. Results -->
            <div class="card sk-card mb-4">
                <h5 class="fw-bold mb-2">Processed Results</h5>
                <p class="text-muted">
                    Analysis results will appear here after generating report.
                </p>
                <small class="text-muted">Status: Awaiting upload...</small>
            </div>

            <!-- 4. Graph -->
            <div class="card sk-card mb-4 text-center">
                <div class="graph-placeholder"></div>
                <small class="text-muted">Graphical summary</small>
            </div>

            <!-- 5. Bottom Actions -->
            <div class="action-sticky-bottom">
                <button id="suggestBtn" class="btn btn-light">Suggestion</button>
                <button id="generateBtn" class="btn btn-success px-4">Generate Report</button>
            </div>

        </div>
    </div>

    @await Html.PartialAsync("_ChatbotPartial")
</div>