@model Skinalyze.ViewModels.ReportViewModel
@{
    ViewData["Title"] = "Patient Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ReportForm.css" />
}

<div class="report-page">

    <!-- Left decorative panel -->
    <div class="report-deco" aria-hidden="true">
        <div class="report-deco-inner">
            <div class="deco-logo">
                <span class="deco-logo-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18" />
                    </svg>
                </span>
                <span class="deco-logo-text">Skinalyze</span>
            </div>
            <h2 class="deco-heading">Generate Your<br />Medical Report</h2>
            <p class="deco-sub">Fill in patient details to create a personalised PDF report with your skin analysis results.</p>
            <ul class="deco-checklist">
                <li>
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
                        <polyline points="4 10 8 14 16 6" />
                    </svg>
                    AI-generated prediction included
                </li>
                <li>
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
                        <polyline points="4 10 8 14 16 6" />
                    </svg>
                    Grad-CAM heatmap attached
                </li>
                <li>
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
                        <polyline points="4 10 8 14 16 6" />
                    </svg>
                    Downloadable PDF with your name
                </li>
            </ul>
        </div>
        <div class="deco-blob deco-blob-1"></div>
        <div class="deco-blob deco-blob-2"></div>
    </div>

    <!-- Right form panel -->
    <div class="report-form-panel">

        <div class="report-form-card">

            <div class="rfc-header">
                <h1>Patient Information</h1>
                <p>All fields are required to generate the report.</p>
            </div>

            <form asp-action="GeneratePdf" method="post" target="_blank"
                  id="reportForm" novalidate>

                <!-- Name row -->
                <div class="rf-row">
                    <div class="rf-field" id="field-FirstName">
                        <label for="FirstName">First Name</label>
                        <div class="rf-input-wrap">
                            <svg class="rf-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                            <input asp-for="FirstName" id="FirstName" type="text"
                                   placeholder="e.g. Sarah" autocomplete="given-name" />
                        </div>
                        <span class="rf-error" id="err-FirstName"></span>
                    </div>

                    <div class="rf-field" id="field-LastName">
                        <label for="LastName">Last Name</label>
                        <div class="rf-input-wrap">
                            <svg class="rf-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                            <input asp-for="LastName" id="LastName" type="text"
                                   placeholder="e.g. Khan" autocomplete="family-name" />
                        </div>
                        <span class="rf-error" id="err-LastName"></span>
                    </div>
                </div>

                <!-- Age & Occupation row -->
                <div class="rf-row">
                    <div class="rf-field" id="field-Age">
                        <label for="Age">Age</label>
                        <div class="rf-input-wrap">
                            <svg class="rf-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                <line x1="16" y1="2" x2="16" y2="6" />
                                <line x1="8" y1="2" x2="8" y2="6" />
                                <line x1="3" y1="10" x2="21" y2="10" />
                            </svg>
                            <input asp-for="Age" id="Age" type="number"
                                   placeholder="e.g. 34" min="1" max="120"
                                   autocomplete="off" />
                        </div>
                        <span class="rf-error" id="err-Age"></span>
                    </div>

                    <div class="rf-field" id="field-Occupation">
                        <label for="Occupation">Occupation</label>
                        <div class="rf-input-wrap">
                            <svg class="rf-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="7" width="20" height="14" rx="2" ry="2" />
                                <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />
                                <line x1="12" y1="12" x2="12" y2="16" />
                                <line x1="10" y1="14" x2="14" y2="14" />
                            </svg>
                            <input asp-for="Occupation" id="Occupation" type="text"
                                   placeholder="e.g. Engineer" autocomplete="organization-title" />
                        </div>
                        <span class="rf-error" id="err-Occupation"></span>
                    </div>
                </div>

                <!-- Family history -->
                <div class="rf-field rf-field-full" id="field-FamilyHistory">
                    <label for="FamilyHistory">Family Disease History</label>
                    <div class="rf-input-wrap rf-textarea-wrap">
                        <svg class="rf-icon rf-icon-top" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                            <polyline points="9 22 9 12 15 12 15 22" />
                        </svg>
                        <textarea asp-for="FamilyHistory" id="FamilyHistory" rows="3"
                                  placeholder="e.g. Father had melanoma, no other known skin conditions…"></textarea>
                    </div>
                    <span class="rf-error" id="err-FamilyHistory"></span>
                </div>

                <!-- Submit -->
                <div class="rf-submit-row">
                    <button type="submit" class="rf-submit-btn" id="generateBtn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                            <polyline points="14 2 14 8 20 8" />
                            <line x1="16" y1="13" x2="8" y2="13" />
                            <line x1="16" y1="17" x2="8" y2="17" />
                            <polyline points="10 9 9 9 8 9" />
                        </svg>
                        Generate PDF Report
                    </button>
                    <a asp-action="Upload" class="rf-back-link">← Back to results</a>
                </div>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    <script>
        (function () {
            const form        = document.getElementById("reportForm");
            const generateBtn = document.getElementById("generateBtn");

            /* ── Field rules ── */
            const rules = [
                {
                    id: "FirstName",
                    label: "First name",
                    validate: v => v.trim().length >= 2 ? null : "First name must be at least 2 characters."
                },
                {
                    id: "LastName",
                    label: "Last name",
                    validate: v => v.trim().length >= 2 ? null : "Last name must be at least 2 characters."
                },
                {
                    id: "Age",
                    label: "Age",
                    validate: v => {
                        const n = parseInt(v, 10);
                        if (!v.trim() || isNaN(n)) return "Please enter a valid age.";
                        if (n < 1 || n > 120)     return "Age must be between 1 and 120.";
                        return null;
                    }
                },
                {
                    id: "Occupation",
                    label: "Occupation",
                    validate: v => v.trim().length >= 2 ? null : "Occupation must be at least 2 characters."
                },
                {
                    id: "FamilyHistory",
                    label: "Family history",
                    validate: v => v.trim().length >= 3 ? null : "Please describe your family disease history."
                }
            ];

            /* ── Show / clear individual error ── */
            function setError(id, msg) {
                const field = document.getElementById("field-" + id);
                const err   = document.getElementById("err-" + id);
                if (!field || !err) return;
                if (msg) {
                    err.textContent = msg;
                    field.classList.add("rf-invalid");
                } else {
                    err.textContent = "";
                    field.classList.remove("rf-invalid");
                    field.classList.add("rf-valid");
                }
            }

            /* ── Live validation on blur ── */
            rules.forEach(rule => {
                const el = document.getElementById(rule.id);
                if (!el) return;
                el.addEventListener("blur", () => setError(rule.id, rule.validate(el.value)));
                el.addEventListener("input", () => {
                    if (document.getElementById("field-" + rule.id).classList.contains("rf-invalid")) {
                        setError(rule.id, rule.validate(el.value));
                    }
                });
            });

            /* ── Submit validation ── */
            form.addEventListener("submit", function (e) {
                let firstInvalid = null;
                let hasError     = false;

                rules.forEach(rule => {
                    const el  = document.getElementById(rule.id);
                    const msg = rule.validate(el ? el.value : "");
                    setError(rule.id, msg);
                    if (msg) {
                        hasError = true;
                        if (!firstInvalid) firstInvalid = el;
                    }
                });

                if (hasError) {
                    e.preventDefault();
                    if (firstInvalid) firstInvalid.focus();

                    // Toast if available
                    if (typeof showToast === "function") {
                        showToast("Please fix the errors above before generating the report.", "error");
                    }
                    return;
                }

                /* Dynamic redirect after PDF opens */
                setTimeout(function () {
                    window.location.href = "/Home/ThankYou";
                }, 1200);

                /* Loading state */
                generateBtn.disabled = true;
                generateBtn.innerHTML = `
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round" width="16" height="16"
                         style="animation:spin 1s linear infinite">
                        <polyline points="1 4 1 10 7 10"/>
                        <path d="M3.51 15a9 9 0 1 0 .49-4"/>
                    </svg>
                    Generating…
                `;
            });
        })();
    </script>
}
