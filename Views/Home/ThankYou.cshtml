@{
    ViewData["Title"] = "Thank You";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
}

<style>
    :root {
        --green: #0D5F4A;
        --green-dk: #0a4a39;
        --green-lt: #eaf5ef;
        --green-mid: #d8ece5;
        --text: #0a1a14;
        --muted: #4a5a55;
        --muted-lt: #6b7e7a;
        --border: #e2ede9;
        --white: #ffffff;
    }

    /* ── Full-page centering ──────────────────────────────────── */
    .ty-wrapper {
        min-height: calc(100vh - 68px);
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--white);
        padding: 60px 24px;
        position: relative;
        overflow: hidden;
    }

    /* ── Decorative background circles (matches Home.css palette) */
    .ty-bg-circle {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        z-index: 0;
    }

    .ty-bg-circle-1 {
        width: 520px;
        height: 520px;
        background: var(--green-mid);
        top: -180px;
        right: -160px;
        opacity: 0.45;
    }

    .ty-bg-circle-2 {
        width: 320px;
        height: 320px;
        background: var(--green-lt);
        bottom: -100px;
        left: -80px;
        opacity: 0.6;
    }

    /* ── Card ─────────────────────────────────────────────────── */
    .ty-card {
        position: relative;
        z-index: 1;
        background: var(--white);
        border: 1.5px solid var(--border);
        border-radius: 28px;
        padding: 64px 72px;
        max-width: 600px;
        width: 100%;
        text-align: center;
        box-shadow: 0 8px 48px rgba(13,95,74,0.09);
        animation: cardIn 0.6s cubic-bezier(0.34,1.3,0.64,1) both;
    }

    @@keyframes cardIn {
        from {
            opacity: 0;
            transform: translateY(28px) scale(0.97);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    /* ── Check icon ───────────────────────────────────────────── */
    .ty-icon-wrap {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: var(--green-lt);
        border: 1.5px solid rgba(13,95,74,0.18);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 32px;
        animation: iconPop 0.65s cubic-bezier(0.34,1.56,0.64,1) 0.2s both;
    }

    @@keyframes iconPop {
        from {
            opacity: 0;
            transform: scale(0.4);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .ty-icon-wrap svg {
        width: 36px;
        height: 36px;
        stroke: var(--green);
        stroke-width: 2.5;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-dasharray: 60;
        stroke-dashoffset: 60;
        fill: none;
        animation: drawCheck 0.5s ease 0.7s forwards;
    }

    @@keyframes drawCheck {
        to {
            stroke-dashoffset: 0;
        }
    }

    /* ── Eyebrow ──────────────────────────────────────────────── */
    .ty-eyebrow {
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        font-weight: 600;
        color: var(--green);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin: 0 0 14px;
        opacity: 0;
        animation: fadeUp 0.5s ease 0.35s forwards;
    }

    /* ── Heading ──────────────────────────────────────────────── */
    .ty-heading {
        font-family: 'DM Sans', sans-serif;
        font-size: clamp(32px, 5vw, 46px);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.12;
        color: var(--text);
        margin: 0 0 10px;
        opacity: 0;
        animation: fadeUp 0.5s ease 0.45s forwards;
    }

        .ty-heading em {
            font-family: 'DM Serif Display', serif;
            font-style: italic;
            font-weight: 400;
            color: var(--green);
        }

    /* ── Sub text ─────────────────────────────────────────────── */
    .ty-sub {
        font-family: 'DM Sans', sans-serif;
        font-size: 16px;
        font-weight: 400;
        color: var(--muted);
        line-height: 1.65;
        max-width: 420px;
        margin: 0 auto 40px;
        opacity: 0;
        animation: fadeUp 0.5s ease 0.55s forwards;
    }

    /* ── Pill button — mirrors .hero-cta ─────────────────────── */
    .ty-btn {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        background: var(--green);
        color: var(--white);
        font-family: 'DM Sans', sans-serif;
        font-size: 16px;
        font-weight: 600;
        padding: 14px 32px;
        border-radius: 50px;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
        box-shadow: 0 4px 18px rgba(13,95,74,0.22);
        opacity: 0;
        animation: fadeUp 0.5s ease 0.68s forwards;
    }

        .ty-btn:hover {
            background: var(--green-dk);
            color: var(--white);
            text-decoration: none;
            transform: translateY(-2px);
            box-shadow: 0 6px 24px rgba(13,95,74,0.30);
        }

        .ty-btn:active {
            transform: scale(0.97);
        }

        .ty-btn svg {
            width: 16px;
            height: 16px;
            stroke: var(--white);
            stroke-width: 2.2;
            stroke-linecap: round;
            stroke-linejoin: round;
            fill: none;
            flex-shrink: 0;
            transition: transform 0.2s;
        }

        .ty-btn:hover svg {
            transform: translateX(3px);
        }

    /* ── Divider ──────────────────────────────────────────────── */
    .ty-divider {
        width: 48px;
        height: 1px;
        background: var(--border);
        margin: 40px auto 28px;
        opacity: 0;
        animation: fadeIn 0.5s ease 0.85s forwards;
    }

    /* ── Report badge row ─────────────────────────────────────── */
    .ty-badge-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        opacity: 0;
        animation: fadeIn 0.5s ease 0.9s forwards;
        margin-bottom: 28px;
    }

    .ty-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--green-lt);
        border: 1px solid rgba(13,95,74,0.14);
        border-radius: 50px;
        padding: 6px 14px;
        font-family: 'DM Sans', sans-serif;
        font-size: 12.5px;
        font-weight: 600;
        color: var(--green);
    }

        .ty-badge svg {
            width: 13px;
            height: 13px;
            stroke: var(--green);
            stroke-width: 2.2;
            stroke-linecap: round;
            stroke-linejoin: round;
            fill: none;
        }

    /* ── Stars row ────────────────────────────────────────────── */
    .ty-stars {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        opacity: 0;
        animation: fadeIn 0.5s ease 0.95s forwards;
        margin-bottom: 28px;
    }

    .stars-text {
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        color: var(--muted-lt);
    }

    /* ── Creators ─────────────────────────────────────────────── */
    .ty-creators {
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        color: var(--muted-lt);
        line-height: 1.8;
        opacity: 0;
        animation: fadeIn 0.5s ease 1.05s forwards;
    }

        .ty-creators strong {
            display: block;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: #9aada7;
            margin-bottom: 4px;
        }

    /* ── Animations ───────────────────────────────────────────── */
    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(14px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    /* ── Responsive ───────────────────────────────────────────── */
    @@media (max-width: 640px) {
        .ty-card {
            padding: 44px 28px;
        }
    }
</style>

<div class="ty-wrapper">

    <!-- Decorative bg blobs -->
    <div class="ty-bg-circle ty-bg-circle-1"></div>
    <div class="ty-bg-circle ty-bg-circle-2"></div>

    <div class="ty-card">

        <!-- Animated check icon -->
        <div class="ty-icon-wrap">
            <svg viewBox="0 0 24 24">
                <polyline points="20 6 9 17 4 12" />
            </svg>
        </div>

        <!-- Eyebrow -->
        <p class="ty-eyebrow">Skinalyze &nbsp;·&nbsp; Report Generated</p>

        <!-- Heading -->
        <h1 class="ty-heading">Thank <em>you!</em></h1>

        <!-- Body -->
        <p class="ty-sub">
            Your skin lesion analysis report has been successfully
            generated. We hope Skinalyze helps guide your next steps
            toward better skin health.
        </p>

        <!-- Badge row -->
        <div class="ty-badge-row">
            <span class="ty-badge">
                <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                PDF Report Ready
            </span>
            <span class="ty-badge">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                AI Analysis Complete
            </span>
        </div>

        <!-- Stars -->
        <div class="ty-stars">
            <span class="stars-text">AI-powered · Dermatology focused</span>
        </div>

        <!-- CTA button -->
        <a asp-controller="Home" asp-action="Index" class="ty-btn">
            Back to Home
            <svg viewBox="0 0 24 24">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
            </svg>
        </a>

        <!-- Divider -->
        <div class="ty-divider"></div>

        <!-- Creators -->
        <div class="ty-creators">
            <strong>Created by</strong>
            Obaid ur Rehman &nbsp;·&nbsp; Ismaa Azam &nbsp;·&nbsp; Aliyan Khan
        </div>

    </div>
</div>
