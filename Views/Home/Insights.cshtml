@{
    ViewData["Title"] = "Insights";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Insights.css" />
}

<div class="app-wrapper" id="appWrapper">
    <div class="insights-page">

        <!-- ══ HERO ══════════════════════════════════════════════════ -->
        <div class="insights-hero">
            <div class="hero-text">
                <p class="hero-eyebrow">Disease Reference Library</p>
                <h1 class="hero-title">Skin Condition <em>Insights</em></h1>
                <p class="hero-desc">
                    Explore all 39 skin conditions recognised by Skinalyze. Each entry includes
                    a clinical description, severity level, and care recommendations to help
                    you understand what our AI detects.
                </p>
            </div>
            <div class="hero-stats">
                <div class="stat-pill">
                    <span class="stat-dot low"></span>
                    <span><strong>11</strong> Low Severity</span>
                </div>
                <div class="stat-pill">
                    <span class="stat-dot medium"></span>
                    <span><strong>18</strong> Medium Severity</span>
                </div>
                <div class="stat-pill">
                    <span class="stat-dot high"></span>
                    <span><strong>10</strong> High Severity</span>
                </div>
                <div class="stat-pill">
                    <span class="stat-dot" style="background:#ffffff;"></span>
                    <span><strong>39</strong> Total Conditions</span>
                </div>
            </div>
        </div>

        <!-- ══ DISCLAIMER ════════════════════════════════════════════ -->
        <div class="insights-disclaimer">
            <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                <line x1="12" y1="9" x2="12" y2="13" />
                <line x1="12" y1="17" x2="12.01" y2="17" />
            </svg>
            <p>
                <strong>Medical Disclaimer:</strong> The information on this page is for educational reference only and is not a substitute
                for professional medical diagnosis or treatment. Always consult a qualified dermatologist for any skin concerns.
            </p>
        </div>

        <!-- ══ CONTROLS ══════════════════════════════════════════════ -->
        <div class="insights-controls">
            <div class="search-wrap">
                <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input type="text" id="searchInput" placeholder="Search conditions, symptoms…" autocomplete="off" />
            </div>

            <div class="filter-pills">
                <button class="filter-pill active" data-filter="all">
                    All Conditions
                </button>
                <button class="filter-pill" data-filter="Low">
                    <span class="pill-dot"></span> Low
                </button>
                <button class="filter-pill" data-filter="Medium">
                    <span class="pill-dot"></span> Medium
                </button>
                <button class="filter-pill" data-filter="High">
                    <span class="pill-dot"></span> High
                </button>
            </div>

            <div class="results-count" id="resultsCount">39 conditions</div>
        </div>

        <!-- ══ DISEASE GRID ════════════════════════════════════════════ -->
        <div class="disease-grid" id="diseaseGrid">

            <!-- ── LOW severity ──────────────────────────────────────── -->

            <div class="disease-card" data-severity="Low" data-name="akne acne blackheads whiteheads pimples hormonal" onclick="toggleCard(this)">
                <div class="card-strip Low"></div>
                <div class="card-body">
                    <div class="card-top">
                        <h3 class="card-title">Akne (Acne)</h3>
                        <span class="severity-badge Low">Low</span>
                    </div>
                    <p class="card-desc">Akne is a common inflammatory skin condition that occurs when hair follicles become blocked with excess oil, dead skin cells, and bacteria. It is strongly associated with hormonal changes, stress, genetics, and the use of oily skin products. Symptoms include blackheads, whiteheads, red pimples, painful nodules, and sometimes cysts.</p>
                    <div class="card-rec">
                        <strong>Recommendation</strong>
                        Keep skin clean, avoid oily cosmetics, and use mild cleansers. Consult a dermatologist if severe.
                    </div>
                    <div class="card-footer">
                        <span class="card-toggle">Read more <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg></span>
                        <div class="card-type-icon Low"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg></div>
                    </div>
                </div>
            </div>

            <div class="disease-card" data-severity="Low" data-name="benign keratosis aging sun waxy rough patches" onclick="toggleCard(this)">
                <div class="card-strip Low"></div>
                <div class="card-body">
                    <div class="card-top">
                        <h3 class="card-title">Benign Keratosis</h3>
                        <span class="severity-badge Low">Low</span>
                    </div>
                    <p class="card-desc">Benign keratosis refers to harmless skin growths commonly linked to aging and repeated sun exposure. These lesions typically appear as rough, waxy, or slightly raised patches that vary in color. They are non-cancerous but may increase in number over time. Monitoring is recommended if the lesion changes.</p>
                    <div class="card-rec">
                        <strong>Recommendation</strong>
                        Monitor skin changes and protect skin from excessive sunlight.
                    </div>
                    <div class="card-footer">
                        <span class="card-toggle">Read more <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg></span>
                        <div class="card-type-icon Low"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg></div>
                    </div>
                </div>
            </div>

            <div class="disease-card" data-severity="Low" data-name="dermatofibroma benign bump insect bite firm brown" onclick="toggleCard(this)">
                <div class="card-strip Low"></div>
                <div class="card-body">
                    <div class="card-top">
                        <h3 class="card-title">Dermatofibroma</h3>
                        <span class="severity-badge Low">Low</span>
                    </div>
                    <p class="card-desc">Dermatofibroma is a benign skin growth often caused by minor injury such as insect bites or trauma. It appears as a small, firm bump that may be brown or reddish in color. Most lesions are painless but may itch slightly. These growths are harmless and usually do not require treatment.</p>
                    <div class="card-rec">
                        <strong>Recommendation</strong>
                        Usually harmless but consult a dermatologist if growth changes.
                    </div>
                    <div class="card-footer">
                        <span class="card-toggle">Read more <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg></span>
                        <div class="card-type-icon Low"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg></div>
                    </div>
                </div>
            </div>

            <div class="disease-card" data-severity="Low" data-name="hair loss alopecia bald patchy autoimmune hormonal" onclick="toggleCard(this)">
                <div class="card-strip Low"></div>
                <div class="card-body">
                    <div class="card-top">
                        <h3 class="card-title">Hair Loss — Alopecia</h3>
                        <span class="severity-badge Low">Low</span>
                    </div>
                    <p class="card-desc">Alopecia refers to hair loss caused by autoimmune reactions, hormonal imbalance, genetics, or nutritional deficiencies. It may appear as patchy hair loss or thinning of hair. Some forms are temporary, while others may be permanent. Early medical consultation can improve treatment outcomes.</p>
                    <div class="card-rec">
                        <strong>Recommendation</strong>
                        Consult a dermatologist for proper diagnosis and nutritional guidance.
                    </div>
                    <div class="card-footer">
                        <span class="card-toggle">Read more <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg></span>
                        <div class="card-type-icon Low"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg></div>
                    </div>
                </div>
            </div>

            <div class="disease-card" data-severity="Low" data-name="light pigmentation melanin sun spots lighter darker" onclick="toggleCard(this)">
                <div class="card-strip Low"></div>
                <div class="card-body">
                    <div class="card-top">
                        <h3 class="card-title">Light Diseases &amp; Pigmentation Disorders</h3>
                        <span class="severity-badge Low">Low</span>
                    </div>
                    <p class="card-desc">Light-related pigmentation disorders occur due to changes in melanin production caused by sun exposure, genetics, or inflammation. These conditions result in lighter or darker patches on the skin. Symptoms are usually cosmetic but may indicate underlying skin sensitivity.</p>
                    <div class="card-rec">
                        <strong>Recommendation</strong>
                        Protect skin from sunlight.
                    </div>
                    <div class="card-footer">
                        <span class="card-toggle">Read more <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg></span>
                        <div class="card-type-icon Low"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg></div>
                    </div>
                </div>
            </div>

            <div class="disease-card" data-severity="Low" data-name="melanocytic nevi moles pigment benign birthmark" onclick="toggleCard(this)">
                <div class="card-strip Low"></div>
                <div class="card-body">
                    <div class="card-top">
                        <h3 class="card-title">Melanocytic Nevi (Moles)</h3>
                        <span class="severity-badge Low">Low</span>
                    </div>
                    <p class="card-desc">Melanocytic nevi, commonly called moles, are benign skin growths formed from pigment-producing cells. They may appear during childhood or adulthood. Most are harmless but should be monitored for unusual changes such as irregular borders or color variation.</p>
                    <div class="card-rec">
                        <strong>Recommendation</strong>
                        Monitor for changes in size or color.
                    </div>
                    <div class="card-footer">
                        <span class="card-toggle">Read more <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg></span>
                        <div class="card-type-icon Low"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg></div>
                    </div>
                </div>
            </div>

            <div class="disease-card" data-severity="Low" data-name="molluscum contagiosum viral poxvirus bumps round" onclick="toggleCard(this)">
                <div class="card-strip Low"></div>
                <div class="card-body">
                    <div class="card-top">
                        <h3 class="card-title">Molluscum Contagiosum</h3>
                        <span class="severity-badge Low">Low</span>
                    </div>
                    <p class="card-desc">Molluscum contagiosum is a viral skin infection caused by a poxvirus that produces small, round, firm bumps with a central indentation. The lesions are usually painless but may become itchy. It spreads through direct skin contact or contaminated objects. Although generally harmless, it may persist for several months.</p>
                    <div class="card-rec">
                        <strong>Recommendation</strong>
                        Avoid scratching and maintain hygiene.
                    </div>
                    <div class="card-footer">
                        <span class="card-toggle">Read more <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg></span>
                        <div class="card-type-icon Low"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg></div>
                    </div>
                </div>
            </div>

            <div class="disease-card" data-severity="Low" data-name="nail fungus onychomycosis brittle discolored thickened" onclick="toggleCard(this)">
                <div class="card-strip Low"></div>
                <div class="card-body">
                    <div class="card-top">
                        <h3 class="card-title">Nail Fungus (Onychomycosis)</h3>
                        <span class="severity-badge Low">Low</span>
                    </div>
                    <p class="card-desc">Nail fungus is a fungal infection that affects fingernails or toenails. It causes nails to become thickened, brittle, discolored, and sometimes distorted. The infection often develops in warm, moist environments. Without treatment, it may spread to nearby skin or cause discomfort.</p>
                    <div class="card-rec">
                        <strong>Recommendation</strong>
                        Keep nails dry and consult for antifungal treatment.
                    </div>
                    <div class="card-footer">
                        <span class="card-toggle">Read more <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg></span>
                        <div class="card-type-icon Low"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg></div>
                    </div>
                </div>
            </div>

            <div class="disease-card" data-severity="Low" data-name="pigment melanin color darker lighter hormonal sun" onclick="toggleCard(this)">
                <div class="card-strip Low"></div>
                <div class="card-body">
                    <div class="card-top">
                        <h3 class="card-title">Pigment Disorders</h3>
                        <span class="severity-badge Low">Low</span>
                    </div>
                    <p class="card-desc">Pigment disorders involve abnormal changes in skin color caused by variations in melanin production or distribution. These changes may result from sun exposure, inflammation, hormonal changes, or genetic factors. Symptoms include patches of lighter or darker skin. Most pigmentation changes are harmless but may require monitoring.</p>
                    <div class="card-rec">
                        <strong>Recommendation</strong>
                        Protect skin from sun exposure.
                    </div>
                    <div class="card-footer">
                        <span class="card-toggle">Read more <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg></span>
                        <div class="card-type-icon Low"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg></div>
                    </div>
                </div>
            </div>

            <div class="disease-card" data-severity="Low" data-name="pityriasis rosea herald patch oval viral temporary" onclick="toggleCard(this)">
                <div class="card-strip Low"></div>
                <div class="card-body">
                    <div class="card-top">
                        <h3 class="card-title">Pityriasis Rosea</h3>
                        <span class="severity-badge Low">Low</span>
                    </div>
                    <p class="card-desc">Pityriasis rosea typically begins with a single large patch known as a herald patch, followed by multiple smaller oval-shaped lesions spreading across the chest or back. The condition is linked to viral infections. Mild itching may occur, but most cases resolve on their own within several weeks.</p>
                    <div class="card-rec">
                        <strong>Recommendation</strong>
                        Use soothing lotions.
                    </div>
                    <div class="card-footer">
                        <span class="card-toggle">Read more <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg></span>
                        <div class="card-type-icon Low"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg></div>
                    </div>
                </div>
            </div>

            <div class="disease-card" data-severity="Low" data-name="seborrheic keratosis waxy wart benign aging brown black" onclick="toggleCard(this)">
                <div class="card-strip Low"></div>
                <div class="card-body">
                    <div class="card-top">
                        <h3 class="card-title">Seborrheic Keratosis</h3>
                        <span class="severity-badge Low">Low</span>
                    </div>
                    <p class="card-desc">Seborrheic keratosis is a common benign skin growth that appears as waxy, rough, or wart-like lesions. These growths are usually brown, black, or tan and occur more frequently with aging. They are harmless but may resemble malignant lesions. Medical evaluation is recommended if changes occur.</p>
                    <div class="card-rec">
                        <strong>Recommendation</strong>
                        Usually harmless but monitor changes.
                    </div>
                    <div class="card-footer">
                        <span class="card-toggle">Read more <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg></span>
                        <div class="card-type-icon Low"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg></div>
                    </div>
                </div>
            </div>

            <!-- LOW count above should total 11 items including the remaining 4 below -->
            <!-- ── MEDIUM severity ─────────────────────────────────── -->

            <div class="disease-card" data-severity="Medium" data-name="atopic dermatitis chronic inflammatory itchy dry immune" onclick="toggleCard(this)">
                <div class="card-strip Medium"></div>
                <div class="card-body">
                    <div class="card-top">
                        <h3 class="card-title">Atopic Dermatitis</h3>
                        <span class="severity-badge Medium">Medium</span>
                    </div>
                    <p class="card-desc">Atopic dermatitis is a chronic inflammatory skin condition related to immune system sensitivity and genetic factors. It causes dry, itchy, inflamed skin that may crack or bleed. Symptoms include redness, scaling, and intense itching especially around elbows, knees, and neck. Flare-ups are often triggered by allergens or stress.</p>
                    <div class="card-rec">
                        <strong>Recommendation</strong>
                        Use moisturizers regularly, avoid harsh soaps, and consult a dermatologist for medicated creams.
                    </div>
                    <div class="card-footer">
                        <span class="card-toggle">Read more <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg></span>
                        <div class="card-type-icon Medium"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg></div>
                    </div>
                </div>
            </div>

            <div class="disease-card" data-severity="Medium" data-name="chickenpox varicella viral contagious blisters fever rash" onclick="toggleCard(this)">
                <div class="card-strip Medium"></div>
                <div class="card-body">
                    <div class="card-top">
                        <h3 class="card-title">Chickenpox (Varicella)</h3>
                        <span class="severity-badge Medium">Medium</span>
                    </div>
                    <p class="card-desc">Chickenpox is a contagious viral infection caused by the varicella-zoster virus. It spreads through respiratory droplets or direct contact with infected lesions. Symptoms begin with fever and fatigue, followed by an itchy rash that forms fluid-filled blisters. Most cases recover naturally, but complications may occur in adults or immunocompromised individuals.</p>
                    <div class="card-rec">
                        <strong>Recommendation</strong>
                        Maintain hygiene, avoid scratching, and consult a doctor if fever persists.
                    </div>
                    <div class="card-footer">
                        <span class="card-toggle">Read more <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg></span>
                        <div class="card-type-icon Medium"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg></div>
                    </div>
                </div>
            </div>

            <div class="disease-card" data-severity="Medium" data-name="cowpox viral animal rodent blisters crusted sores" onclick="toggleCard(this)">
                <div class="card-strip Medium"></div>
                <div class="card-body">
                    <div class="card-top">
                        <h3 class="card-title">Cowpox</h3>
                        <span class="severity-badge Medium">Medium</span>
                    </div>
                    <p class="card-desc">Cowpox is a rare viral infection transmitted from infected animals such as rodents or cats. It causes localized skin lesions that begin as red spots and progress into blisters and crusted sores. Symptoms may include mild fever and swollen lymph nodes. Most cases resolve without serious complications.</p>
                    <div class="card-rec">
                        <strong>Recommendation</strong>
                        Avoid touching lesions and maintain cleanliness. Seek medical advice if symptoms worsen.
                    </div>
                    <div class="card-footer">
                        <span class="card-toggle">Read more <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg></span>
                        <div class="card-type-icon Medium"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg></div>
                    </div>
                </div>
            </div>

            <div class="disease-card" data-severity="Medium" data-name="eczema inflammatory dry itchy red scaling allergies" onclick="toggleCard(this)">
                <div class="card-strip Medium"></div>
                <div class="card-body">
                    <div class="card-top">
                        <h3 class="card-title">Eczema</h3>
                        <span class="severity-badge Medium">Medium</span>
                    </div>
                    <p class="card-desc">Eczema is a group of inflammatory skin conditions that cause dry, itchy, and inflamed skin. It is commonly associated with allergies, immune sensitivity, and environmental irritants. Symptoms include redness, scaling, cracking, and sometimes fluid-filled blisters. Chronic scratching may lead to skin thickening or infection.</p>
                    <div class="card-rec">
                        <strong>Recommendation</strong>
                        Use moisturizers frequently and avoid known irritants.
                    </div>
                    <div class="card-footer">
                        <span class="card-toggle">Read more <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg></span>
                        <div class="card-type-icon Medium"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg></div>
                    </div>
                </div>
            </div>

            <div class="disease-card" data-severity="Medium" data-name="exanthems drug eruptions medication allergic rash blistering" onclick="toggleCard(this)">
                <div class="card-strip Medium"></div>
                <div class="card-body">
                    <div class="card-top">
                        <h3 class="card-title">Exanthems &amp; Drug Eruptions</h3>
                        <span class="severity-badge Medium">Medium</span>
                    </div>
                    <p class="card-desc">Drug eruptions are skin reactions caused by medications or allergic responses. Symptoms may include widespread redness, rash, itching, or blistering. Reactions usually occur shortly after starting a new medication. Severe forms may involve peeling skin or fever and require urgent medical attention.</p>
                    <div class="card-rec">
                        <strong>Recommendation</strong>
                        Stop suspected medication and consult a healthcare provider immediately.
                    </div>
                    <div class="card-footer">
                        <span class="card-toggle">Read more <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg></span>
                        <div class="card-type-icon Medium"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg></div>
                    </div>
